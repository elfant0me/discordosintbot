# Discord
DISCORD_TOKEN=replace_me
MONITOR_ALERT_CHANNEL_ID=0
MONITOR_GUILD_ID=0

# Alert thresholds
CPU_ALERT_THRESHOLD=85
TEMP_ALERT_THRESHOLD=75
DISK_ALERT_THRESHOLD=90
CHECK_INTERVAL=60

# AdGuard Home
ADGUARD_BASE_URL=http://127.0.0.1
ADGUARD_USERNAME=replace_me
ADGUARD_PASSWORD=replace_me

# Monitoring lists
# Comma-separated systemd services.
MONITOR_SERVICES=AdGuardHome,tailscaled,docker

# Comma-separated disk paths.
MONITOR_DISK_PATHS=/,/home

# Semicolon-separated name=host pairs.
MONITOR_HEALTH_HOSTS=Router=192.168.1.1;Server=192.168.1.10

# Semicolon-separated services.
# Format:
# http|Name|https://example.com
# ping|Name|hostname-or-ip
# tcp|Name|host|port
HOMELAB_SERVICES=http|Jellyfin|https://jellyfin.example.com;ping|Raspberry|raspberrypi;tcp|Game Server|192.168.1.20|9000
